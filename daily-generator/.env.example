# The Climb — Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to git — keep these secret!

# ── Anthropic ──────────────────────────────────────
# Get from: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Supabase ───────────────────────────────────────
# Get from: Supabase dashboard → Settings → API

# Your project URL (looks like https://abcdefgh.supabase.co)
SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co

# Anon key — safe to use in the frontend HTML file
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Service role key — ONLY used in generate.js, never in frontend
# This key bypasses row-level security — keep it secret!
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
